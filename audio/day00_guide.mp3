            <script>

                var smsID = "UYoHPxiI"

                docReady(function () {
                    var u = Lego.utils

                    var query = u.queryParse();

                    if (query && query['active']) {
                        u.attr(u.$('#switcher'), 'active', query['active'])
                    }

                    var handleSuccess = function (data) {
                        switch (data.CallID) {
                            case smsID:
                                Lego.notification({message: '验证码获取成功！', status: "success"})
                                break
                            default:
                                break
                        }
                    }

                    var handleError = function (data) {
                        if (isNaN(data.data.ErrCode)) return
                        switch (data.CallID) {
                            case smsID:
                                var message = data.data.ErrCode === 20 ? "图形验证码错误" : (data.data.Result && data.data.Result.out ? data.data.Result.out  : "出现错误，请刷新重试")
                                Lego.notification({message: message, status: "danger"})
                                break
                            default:
                                break
                        }
                    }


                    var sendSMS = function () {
                        return FetchServer('UYoHPxiI','GET',undefined,undefined);                    }


                    var $countdown = Lego.countdown(u.$("#countdown"), {
                        text: "#valicode",
                        duration: 60,
                    })

                    var $captcha = Lego.slideCaptcha('#slide-captcha', {
                        toggle:"#next-step",
                        destroyable:true,
                        triggerEle:"#countdown",
                        cb: sendSMS,
                        onSuccess: (data) => {
                            $countdown.handleCountDown()
                            handleSuccess(data)
                        },
                        onError: handleError
                    })


                    u.on('#login', 'keyup keypress', function(e) {
                        let keyCode = e.keyCode || e.which;
                        if (keyCode === 13 || e.key === "Enter") {
                            e.preventDefault();
                            return false;
                        }
                    });
                })

            </script>

        </div>


    </div>

<style>
  body {
    overflow: hidden;
  }
  input.lg-input {
    border-width: 0;
    border-bottom-width: 1px;
    padding-left: 0;
  }
  input.lg-input:focus {
    outline: none;
    box-shadow: none;
  }
</style>


<script>

    let apis={"UYoHPxiI":{"url":"\/Nippon\/Master\/SendMobileValidation","query_var":["tg","page_nonce"]}};
    var FetchServer

    docReady(function () {

        var u = Lego.utils

        // Ga tracker
        u.initGA("G-T7GVLBMZLZ", {
                        gaOptions: {
                userId: ""
            }
        })

        function  HeaderAlert (style,strong,msg) {
            Lego.notification({
                message: strong,
                status: style
            })
        }


        FetchServer = function (CallID,method,preCallFunc,afterCallFunc) {
            if(u.isUndefined(apis)){
                HeaderAlert('danger','接口错误',CallID);
                return;
            }

            var call = apis[CallID];

            if(u.isUndefined(call)){
                HeaderAlert('danger','请求ID错误,请刷新浏览器重试',CallID);
                return;
            }

            if(u.isFunction(preCallFunc)){
                preCallFunc();
            }


            var url = call['url'];
            var params ={};
            var isForm = false

            if(method==="POST"){
                params = new FormData();
                isForm = true
            }

            call['query_var'].forEach(

                    //system required parameter
                    function (element,index,array) {
                        switch (element) {
                            case 'page_nonce':
                                var $pageNonce = u.$('#page_nonce')
                                isForm ? params.append(element, $pageNonce.value) : params[element] = $pageNonce.value
                                break;
                            case 'tk':
                                var $tk = u.$('#tk')
                                isForm ? params.append(element, $tk.value) : params[element] = $tk.value
                                break;
                            default:
                                var targetCondition = '[call-id="'+CallID+'"][for-param="'+element+'"]';
                                var inputEl = u.$(targetCondition);

                                if(typeof inputEl === 'undefined'){
                                    return;
                                }
                                switch (
                                inputEl
                                && inputEl.previousElementSibling
                                && inputEl.previousElementSibling.nodeName.toLowerCase()) {
                                    case 'file':
                                        var fileCount = inputEl.files.length;
                                        for(var i=0;i<fileCount;i++){
                                            params.append("file[]",inputEl.files[i]);
                                        }
                                        break;
                                    default:
                                        isForm ? params.append(element, inputEl.value) : params[element] = inputEl.value;
                                        break;
                                }
                                break;
                        }

                    }
            );


            var deferred = new Lego.utils.Deferred();

            u.ajax(url, {
                data: params,
                method: method,
                cache:false,
                headers: u.getPassportHeader(),
            }).then(function(data, textStatus, request) {
                if (data.ErrCode === 0) {
                    let node = u.$('[result-for="'+CallID+'"]');
                    if(typeof node === 'undefined'){
                        return;
                    }
                    switch (u.attr(node, 'update-type')) {
                        case 'base64src':
                            u.attr(node, 'src', "data:image/png;base64,"+data.Result)
                            break;
                        case 'append':
                            u.append(node, data.Result)
                            break;
                        case 'replace':
                            u.empty(node).append(node, data.Result)
                            break;
                    }
                    if(typeof after  ==='function'){
                        after();
                    }
                    deferred.resolve({
                        data: data,
                        CallID: CallID
                    })
                } else {
                    deferred.reject({
                        data: data,
                        CallID: CallID
                    })
                }

            }).catch(function(xhr) {
                deferred.reject({
                    code: 911,
                    CallID: CallID
                });
            });
            return deferred.promise

        }
    })
</script>
